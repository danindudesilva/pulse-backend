// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String            @id @default(cuid())
  clerkUserId String            @unique
  email       String            @unique
  name        String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  memberships WorkspaceMember[]

  @@map("users")
  opportunitiesCreated Opportunity[] @relation("OpportunityCreatedBy")
}

model Workspace {
  id        String            @id @default(cuid())
  name      String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  members   WorkspaceMember[]

  @@map("workspaces")
  opportunities Opportunity[]
}

model WorkspaceMember {
  workspaceId String
  userId      String
  role        WorkspaceRole
  createdAt   DateTime      @default(now())

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

enum WorkspaceRole {
  owner
  member
}

enum OpportunityStatus {
  draft
  sent
  replied
  won
  lost
  paused
}

model Opportunity {
  id              String            @id @default(cuid())
  workspaceId     String
  createdByUserId String
  title           String
  companyName     String?
  contactName     String?
  contactEmail    String?
  valueAmount     Decimal?          @db.Decimal(12, 2)
  currency        String?
  notes           String?
  status          OpportunityStatus
  quoteSentAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy        User             @relation("OpportunityCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, createdByUserId])
  @@map("opportunities")
}
